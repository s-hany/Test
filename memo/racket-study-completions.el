(defun racket-study--candidate-item (candidate)
  "Return the study item stored on CANDIDATE."
  (get-text-property 0 'racket-study-item candidate))

(defun racket-study--make-candidate (item)
  "Return a Company candidate string for ITEM."
  (let ((candidate (copy-sequence (plist-get item :name))))
    (put-text-property 0 (length candidate) 'racket-study-item item candidate)
    candidate))

(defun racket-study--completion-prefix ()
  "Return the Racket symbol prefix at point."
  (when (and (or (derived-mode-p 'racket-mode)
                 (derived-mode-p 'racket-repl-mode))
             (not (nth 3 (syntax-ppss)))
             (not (nth 4 (syntax-ppss))))
    (let ((end (point))
          start prefix)
      (save-excursion
        (skip-chars-backward "A-Za-z0-9_+*/<>=?!$%&~^:.-")
        (setq start (point)))
      (setq prefix (buffer-substring-no-properties start end))
      (when (> (length prefix) 0)
        prefix))))

(defun racket-study--candidates (prefix)
  "Return study candidates matching PREFIX in priority order."
  (cl-loop for item in racket-study-completion-items
           for name = (plist-get item :name)
           when (string-prefix-p prefix name)
           collect (racket-study--make-candidate item)))

(defun racket-study--definition-candidate-p (item)
  "Return non-nil when ITEM inserts a study definition."
  (memq (plist-get item :kind) '(math-def example-def)))

(defun racket-study--defined-in-buffer-p (name)
  "Return non-nil when the current buffer has a top-level define for NAME."
  (let ((regexp (concat "^[[:space:]]*(define[[:space:]]+\\(?:([[:space:]]*"
                        (regexp-quote name)
                        "\\(?:[[:space:]]\\|)\\)\\|"
                        (regexp-quote name)
                        "\\(?:[[:space:]]\\|)\\)\\)")))
    (save-excursion
      (save-restriction
        (widen)
        (goto-char (point-min))
        (re-search-forward regexp nil t)))))

(defun racket-study--call-candidate-p (item)
  "Return non-nil when ITEM should complete as a function call."
  (and (racket-study--definition-candidate-p item)
       (racket-study--defined-in-buffer-p (plist-get item :name))))

(defun racket-study--annotation (candidate)
  "Return a short annotation for CANDIDATE."
  (let* ((item (racket-study--candidate-item candidate))
         (kind (plist-get item :kind)))
    (pcase kind
      ('builtin " [builtin]")
      ('math-def (if (racket-study--call-candidate-p item)
                     " [math call]"
                   " [math define]"))
      ('example-def (if (racket-study--call-candidate-p item)
                        " [example call]"
                      " [example define]"))
      (_ ""))))

(defun racket-study--meta (candidate)
  "Return metadata for CANDIDATE."
  (let* ((item (racket-study--candidate-item candidate))
         (kind (plist-get item :kind)))
    (if (racket-study--call-candidate-p item)
        (pcase kind
          ('math-def "math call  already defined in this buffer")
          ('example-def "example call  already defined in this buffer")
          (_ (plist-get item :meta)))
      (plist-get item :meta))))

(defun racket-study--doc-buffer (candidate)
  "Return a documentation buffer for CANDIDATE."
  (let ((item (racket-study--candidate-item candidate)))
    (company-doc-buffer (or (plist-get item :doc) ""))))

(defun racket-study--post-completion (candidate)
  "Insert definition forms for definition CANDIDATEs."
  (let* ((item (racket-study--candidate-item candidate))
         (name (plist-get item :name))
         (kind (plist-get item :kind))
         (replacement (plist-get item :insert)))
    (when (and replacement
               (> (length replacement) 0)
               (not (racket-study--call-candidate-p item)))
      (let* ((end (point))
             (start (max (point-min) (- end (length name))))
             (delete-open-paren (and (memq kind '(math-def example-def))
                                     (> start (point-min))
                                     (eq (char-before start) 40))))
        (delete-region (if delete-open-paren (1- start) start) end)
        (insert replacement)))))

;;;###autoload
(defun company-racket-study (command &optional arg &rest _ignored)
  "Company backend for local Racket study completions."
  (interactive (list 'interactive))
  (cl-case command
    (interactive (company-begin-backend 'company-racket-study))
    (prefix (let ((prefix (racket-study--completion-prefix)))
              (when (and prefix (racket-study--candidates prefix))
                prefix)))
    (candidates (racket-study--candidates arg))
    (annotation (racket-study--annotation arg))
    (meta (racket-study--meta arg))
    (doc-buffer (racket-study--doc-buffer arg))
    (post-completion (racket-study--post-completion arg))
    (sorted t)
    (duplicates nil)))

(provide 'racket-study-completions)
